// Beacon5 v2 — Firestore security rules
// Source: PRD §10–12. Tenant isolation by `campusId`; role-based read/write;
// audit log immutable; clients NEVER write to most paths (server-only via Admin SDK).
//
// CUSTOM CLAIMS expected on auth tokens (set server-side after login):
//   - campusId:        string       — the user's campus tenant
//   - role:            'student' | 'parent' | 'staff' | 'admin'
//   - linkedStudents:  string[]     — for parents, the student userIds they may see
//
// ⚠ DO NOT DEPLOY YET — see server/firestore-rules/README.md
//   These rules require auth + custom claims (Phase 0 step 2). Deploying
//   before step 2 will lock out the running v1 monolith and any unauth'd
//   client. Stay in test-mode rules until step 2 lands.

rules_version = '2';

service cloud.firestore {
  match /databases/{db}/documents {

    // ────────── helpers ──────────
    function isAuthed()      { return request.auth != null; }
    function role()          { return request.auth.token.role; }
    function uid()           { return request.auth.uid; }
    function tokenCampus()   { return request.auth.token.campusId; }
    function sameCampus(cid) { return isAuthed() && tokenCampus() == cid; }

    function isAdmin()       { return isAuthed() && role() == 'admin'; }
    function isStaff()       { return isAuthed() && (role() == 'staff' || role() == 'admin'); }
    function isStudent()     { return isAuthed() && role() == 'student'; }
    function isParent()      { return isAuthed() && role() == 'parent'; }

    function isLinkedGuardian(studentId) {
      return isParent()
        && studentId in request.auth.token.linkedStudents;
    }

    // Helper to look up the parent incident's studentUserId from a subcollection rule.
    function incidentStudent(cid, iid) {
      return get(/databases/$(db)/documents/campuses/$(cid)/incidents/$(iid)).data.studentUserId;
    }

    // ────────── organizations ──────────
    // Read for any authed user (needed to render org name); writes only via server.
    match /organizations/{orgId} {
      allow read:  if isAuthed();
      allow write: if false;
    }

    // ────────── campuses (tenant root) ──────────
    match /campuses/{cid} {
      allow read:  if sameCampus(cid);
      allow write: if false; // server only (Admin SDK creates/updates campuses)

      // Users — own profile + staff can list roster
      match /users/{userId} {
        allow read:  if sameCampus(cid) && (userId == uid() || isStaff());
        allow write: if false;
      }

      // Guardian links — staff/admin only (used to render parent ↔ child)
      match /guardianLinks/{linkId} {
        allow read:  if sameCampus(cid) && isStaff();
        allow write: if false;
      }

      // Zones — readable to anyone in-campus; written by admin via server
      match /zones/{zoneId} {
        allow read:  if sameCampus(cid);
        allow write: if false;
      }

      // Campus threats — readable to anyone in-campus; declared/cleared only
      // via server endpoint with step-up auth (R8.2.3 / R8.4.2).
      match /campusThreats/{threatId} {
        allow read:  if sameCampus(cid);
        allow write: if false;
      }

      // Incidents — staff see all; student sees own; parent sees linked-child only
      match /incidents/{incidentId} {
        allow read: if sameCampus(cid) && (
          isStaff()
          || (isStudent() && resource.data.studentUserId == uid())
          || (isParent()  && isLinkedGuardian(resource.data.studentUserId))
        );
        allow write: if false;

        // Location points — same scope as the parent incident.
        // R8.6 — never readable outside an active incident; retention purge handled server-side.
        match /locationPoints/{pointId} {
          allow read: if sameCampus(cid) && (
            isStaff()
            || (isStudent() && incidentStudent(cid, incidentId) == uid())
            || (isParent()  && isLinkedGuardian(incidentStudent(cid, incidentId)))
          );
          allow write: if false;
        }
      }

      // Messages — chat, broadcast, mass. Immutable: server-only writes,
      // no client updates or deletes ever. Retraction in UI is a new
      // "superseded" message, not an edit (R8.8.3).
      match /messages/{messageId} {
        allow read: if sameCampus(cid) && (
          // staff & admin see everything
          isStaff()
          // anyone sees messages they authored
          || resource.data.senderUserId == uid()
          // student sees mass broadcasts targeting students/everyone
          || (isStudent() && resource.data.kind == 'mass'
              && (('students' in resource.data.audience) || ('everyone' in resource.data.audience)))
          // parent sees mass broadcasts targeting parents/everyone, plus chats about their linked child
          || (isParent() && (
              (resource.data.kind == 'mass'
                && (('parents' in resource.data.audience) || ('everyone' in resource.data.audience)))
              || (resource.data.kind == 'chat'
                && isLinkedGuardian(resource.data.studentUserId))
            ))
        );
        allow write: if false;
      }

      // Audit events — admin-only read; never written, updated, or deleted from client.
      // R8.10.6 + R11.2 immutability requirement.
      match /auditEvents/{eventId} {
        allow read:  if sameCampus(cid) && isAdmin();
        allow write: if false;
      }

      // Consent records — own record or admin
      match /consentRecords/{recordId} {
        allow read:  if sameCampus(cid)
                    && (isAdmin() || resource.data.userId == uid());
        allow write: if false;
      }

      // Devices — own only (push token registration via server endpoint)
      match /devices/{deviceId} {
        allow read:  if sameCampus(cid) && resource.data.userId == uid();
        allow write: if false;
      }

      // Join codes — staff/admin readable for management; clients never
      // read them directly (redemption happens server-side via /v1/auth/join).
      // Server writes via Admin SDK only.
      match /joinCodes/{code} {
        allow read:  if sameCampus(cid) && isStaff();
        allow write: if false;
      }
    }

    // ────────── deny everything else ──────────
    // Defense in depth. Any path not matched above is rejected.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
