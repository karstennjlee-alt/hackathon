# ════════════════════════════════════════════════════════════════════
#  Beacon5 SERVER environment
#  SERVER-ONLY SECRETS. NEVER duplicate any of these into app/.env,
#  admin/.env, EXPO_PUBLIC_*, or VITE_* — they are not client-safe.
#  Every blank below maps to a section of KEYS.md.
# ════════════════════════════════════════════════════════════════════

# ── runtime ───────────────────────────────────────────────────────
NODE_ENV=development          # development | staging | production
PORT=4000
LOG_LEVEL=info                # debug | info | warn | error

# ── Supabase (Postgres + Auth + Realtime + Storage) — KEYS.md §1 ──
SUPABASE_URL=
# sb_publishable_* — also used by the server for user-scoped operations
SUPABASE_PUBLISHABLE_KEY=
# service_role (sb_secret_*) — BYPASSES ALL RLS. Server-only. KMS in prod.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret — used to verify user tokens server-side.
SUPABASE_JWT_SECRET=
# Postgres direct connection (port 6543 with PgBouncer pooling).
SUPABASE_DB_URL=

# ── Gemini (server-only) — KEYS.md §2 ─────────────────────────────
# ⚠ Rotate the v1 EXPO_PUBLIC_GEMINI_API_KEY — it's exposed in v1 git history.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Google Geocoding (server-only) — KEYS.md §3 ───────────────────
GOOGLE_GEOCODING_API_KEY=

# ── Sign in with Apple (configured in Supabase dashboard, not used directly
#    on this server when Supabase brokers auth — keep for reference) — KEYS.md §4
APPLE_TEAM_ID=
APPLE_SERVICES_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey_XXXXXX.p8

# ── Google OAuth (configured in Supabase dashboard) — KEYS.md §5 ──
GOOGLE_OAUTH_WEB_CLIENT_ID=

# ── APNs (Apple Push) — KEYS.md §6 ────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY_PATH=./secrets/AuthKey_APNS_XXXXXX.p8
APNS_BUNDLE_ID=com.beacon5.app
APNS_ENV=sandbox

# ── FCM (Android Push) — KEYS.md §7 — standalone Firebase project ──
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm-service-account.json
# Alternative inline:
# FCM_SERVICE_ACCOUNT_JSON=

# ── Expo Push (optional alt to direct APNs/FCM) — KEYS.md §8 ──────
EXPO_ACCESS_TOKEN=
EAS_PROJECT_ID=

# ── Sentry (crash reporting) — KEYS.md §10 ────────────────────────
SENTRY_DSN=

# ── KMS (production only) — KEYS.md §11 ───────────────────────────
KMS_PROVIDER=                 # gcp | aws | azure
KMS_KEY_RESOURCE=
