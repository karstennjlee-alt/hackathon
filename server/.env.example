# ════════════════════════════════════════════════════════════════════
#  Beacon5 SERVER environment
#  SERVER-ONLY SECRETS. NEVER duplicate any of these into app/.env,
#  admin/.env, EXPO_PUBLIC_*, or VITE_* — they are not client-safe.
#  Every blank below maps to a section of KEYS.md.
# ════════════════════════════════════════════════════════════════════

# ── runtime ───────────────────────────────────────────────────────
NODE_ENV=development          # development | staging | production
PORT=4000
LOG_LEVEL=info                # debug | info | warn | error

# ── Firebase Admin SDK — KEYS.md §1 ───────────────────────────────
# Firebase console → Project settings → Service accounts → "Generate new private key"
# Save the JSON to server/secrets/ (gitignored).
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# (Alternative) inline JSON instead of a file path:
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Gemini (server-only) — KEYS.md §2 ─────────────────────────────
# https://aistudio.google.com/app/apikey  → restrict to Generative Language API.
# ⚠ Rotate the v1 key before reusing — the old EXPO_PUBLIC_GEMINI_API_KEY
#    is exposed in v1 git history (commit af2996f).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Google Geocoding (server-only) — KEYS.md §3 ───────────────────
# Restrict to Geocoding API only + server IP allowlist in prod.
GOOGLE_GEOCODING_API_KEY=

# ── Sign in with Apple (server verification) — KEYS.md §4 ─────────
APPLE_TEAM_ID=
APPLE_SERVICES_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey_XXXXXX.p8

# ── Google OAuth (web client used for server-side ID-token verify) — KEYS.md §5 ──
GOOGLE_OAUTH_WEB_CLIENT_ID=

# ── APNs (Apple Push) — KEYS.md §6 ────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY_PATH=./secrets/AuthKey_APNS_XXXXXX.p8
APNS_BUNDLE_ID=com.beacon5.app
APNS_ENV=sandbox              # sandbox for TestFlight; production for App Store

# ── FCM (Android Push) — KEYS.md §7 ───────────────────────────────
# FCM uses the Firebase Admin SDK service account from §1 above.
# No separate var needed; the Admin SDK handles it.

# ── Expo Push (optional alt to direct APNs/FCM) — KEYS.md §8 ──────
EXPO_ACCESS_TOKEN=
EAS_PROJECT_ID=

# ── Sentry (crash reporting) — KEYS.md §10 ────────────────────────
SENTRY_DSN=

# ── KMS (production only) — KEYS.md §11 ───────────────────────────
# Leave blank in dev. Required when NODE_ENV=production.
KMS_PROVIDER=                 # gcp | aws | azure
KMS_KEY_RESOURCE=
