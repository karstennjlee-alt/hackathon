# ════════════════════════════════════════════════════════════════════
#  Beacon5 ADMIN console environment
#  CLIENT-SAFE values only — bundled into the React web app.
#  NEVER put server secrets (Gemini, service accounts, .p8s) here.
#  Every blank below maps to a section of KEYS.md.
# ════════════════════════════════════════════════════════════════════

# Beacon5 backend base URL
VITE_API_BASE_URL=http://localhost:4000

# ── Firebase web config (admin web app) — KEYS.md §1.10 ───────────
# Register a separate WEB app under the same Firebase project as the mobile app.
# Restrict each key in Google Cloud → Credentials → HTTP referer = your admin domain.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Google OAuth web client — KEYS.md §5.4 ────────────────────────
# Same web client ID as the server uses for ID-token verification.
VITE_GOOGLE_OAUTH_WEB_CLIENT_ID=

# ── Sentry (DSN is public by design) — KEYS.md §10.2 ──────────────
VITE_SENTRY_DSN=

# ── DO NOT add ────────────────────────────────────────────────────
# - Gemini key, Geocoding key, Firebase service account JSON,
#   APNs/FCM creds, or Apple .p8 file.
# - These live in server/.env. If you find one here, MOVE it and ROTATE it.
