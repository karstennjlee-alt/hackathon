# ════════════════════════════════════════════════════════════════════
#  Beacon5 ADMIN console environment
#  CLIENT-SAFE values only — bundled into the React web app.
#  NEVER put server secrets (Supabase service_role, Gemini, .p8s) here.
#  Every blank below maps to a section of KEYS.md.
# ════════════════════════════════════════════════════════════════════

# Beacon5 backend base URL
VITE_API_BASE_URL=http://localhost:4000

# ── Supabase (Postgres + Auth + Realtime + Storage) — KEYS.md §1 ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Sentry (DSN is public by design) — KEYS.md §10.2 ──────────────
VITE_SENTRY_DSN=

# ── DO NOT add ────────────────────────────────────────────────────
# - Supabase service_role key, Gemini key, Geocoding key,
#   FCM creds, or Apple .p8 file.
# - These live in server/.env. If you find one here, MOVE it and ROTATE it.
