# ════════════════════════════════════════════════════════════════════
#  Beacon5 APP (mobile) environment
#  CLIENT-SAFE values only — every var here is bundled into the JS shipped
#  to users. NEVER put server secrets in this file.
#  Every blank below maps to a section of KEYS.md.
# ════════════════════════════════════════════════════════════════════

# Beacon5 backend base URL — the only thing the app calls for AI / writes / push.
# Dev:     http://localhost:4000  (or your LAN IP)
# Staging: https://api.staging.beacon5.app  (example)
# Prod:    https://api.beacon5.app           (example)
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# ── Supabase (Postgres + Auth + Realtime + Storage) — KEYS.md §1 ──
# URL: safe to expose. Publishable key (sb_publishable_*): designed to be public.
# RLS policies on every table are what actually protect your data.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Google Maps Android (iOS uses Apple Maps natively) — KEYS.md §9 ──
# Restrict by Android package + SHA-1.
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# ── Sentry (DSN is public-by-design) — KEYS.md §10 ────────────────
EXPO_PUBLIC_SENTRY_DSN=

# ── Demo mode flag — DECISIONS.md D11 ─────────────────────────────
# When true, seed/demo data is bundled and shown. Must be false in prod builds.
EXPO_PUBLIC_DEMO=false

# ── DO NOT add ────────────────────────────────────────────────────
# - Supabase service_role key (it's the master key — bypasses RLS),
#   Gemini API key, Geocoding key, FCM service account JSON,
#   APNs/Apple .p8 file, or any KMS reference.
# - Those are SERVER secrets. They live in server/.env.
# - Anything in this file ends up in the JS bundle shipped to every user.
